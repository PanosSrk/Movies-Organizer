<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light Theme -->
    <style name="AppTheme.Light" parent="Theme.Material3.Light">
        <item name="android:textColor">@android:color/black</item>
        <item name="vector_tint">@color/vector_tint_light</item>
        <item name="widget_background">@color/widget_background_light</item>
    </style>

    <!-- Dark Theme -->
    <style name="AppTheme.Dark" parent="Theme.Material3.Dark">
        <item name="android:textColor">@android:color/white</item>
        <item name="vector_tint">@color/vector_tint_dark</item>
        <item name="widget_background">@color/widget_background_dark</item>


    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom</item>
    </style>
</resources>